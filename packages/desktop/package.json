{
	"name": "pi-desktop",
	"version": "0.0.1",
	"private": true,
	"description": "Pi AI Desktop - macOS desktop app for AI chat",
	"author": "Pi Desktop",
	"type": "module",
	"main": "dist-electron/main.mjs",
	"scripts": {
		"dev": "vite",
		"dev:electron": "concurrently --names \"vite,electron\" --prefix-colors \"cyan,green\" \"vite\" \"sleep 3 && electron .\"",
		"build": "vite build && npm run build:electron",
		"build:electron": "tsc -p tsconfig.electron.json && node scripts/rename-to-mjs.cjs && cp electron/preload.js dist-electron/preload.js",
		"preview": "vite preview",
		"package": "npm run build && electron-builder --mac",
		"clean": "shx rm -rf dist dist-electron release"
	},
	"dependencies": {
		"@mariozechner/mini-lit": "^0.2.0",
		"@mariozechner/pi-ai": "file:../ai",
		"@mariozechner/pi-web-ui": "file:../web-ui",
		"@tailwindcss/vite": "^4.1.17",
		"lit": "^3.3.1",
		"lucide": "^0.544.0"
	},
	"devDependencies": {
		"electron": "35.7.5",
		"electron-builder": "^26.0.12",
		"concurrently": "^9.2.1",
		"typescript": "^5.7.3",
		"vite": "^7.1.6"
	},
	"build": {
		"appId": "com.pi.desktop",
		"productName": "Pi Desktop",
		"electronDist": "../../node_modules/electron/dist",
		"mac": {
			"target": ["dmg"],
			"category": "public.app-category.developer-tools"
		},
		"directories": {
			"output": "release"
		},
		"files": [
			"dist/**/*",
			"dist-electron/**/*",
			"!node_modules/electron/**/*"
		]
	}
}
